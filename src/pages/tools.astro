---
import Layout from "../layouts/Layout.astro";
import { getTools, getToolsPage } from "../library/microcms";

type ScriptCard = {
  id: string;
  slug: string;
  title: string;
  summary?: string;
  description?: string;
  tool?: string;
  tags: string[];
  thumbnailUrl?: string;
};

function splitTags(tool?: string) {
  return (tool ?? "")
    .split(/[,\n]/)
    .map((value) => value.trim())
    .filter(Boolean);
}

function stripHtml(html?: string) {
  return (html ?? "").replace(/<[^>]+>/g, " ").replace(/\s+/g, " ").trim();
}

let pageTitle = "Tools";
let pageDescription = "";
try {
  const page = await getToolsPage();
  pageTitle = page.title;
  pageDescription = page.description ?? "";
} catch {
  // Fallback when microCMS is unavailable.
}

let scripts: ScriptCard[] = [];
try {
  const res = await getTools({ orders: "-publishedAt", limit: 100 });
  scripts = res.contents.map((item) => ({
    id: item.id,
    slug: item.slug ?? item.id,
    title: item.title,
    summary: item.summary,
    description: item.description,
    tool: item.tool,
    tags: splitTags(item.tool),
    thumbnailUrl: item.thumbnail?.url,
  }));
} catch {
  scripts = [];
}

const tagTitles = Array.from(new Set(scripts.flatMap((item) => item.tags)));
---

<Layout title={`${pageTitle} | onmk`}>
  <div class="container">
    {pageDescription && (
      <div class="page-head">
        <p class="page-desc" set:html={pageDescription}></p>
      </div>
    )}

    <div class="tag-filter" aria-label="Filter tools by tag">
      <a href="/tools" class="tag-link" data-tag="all">all</a>
      {tagTitles.map((tag) => (
        <a href={`/tools?tag=${encodeURIComponent(tag)}`} class="tag-link" data-tag={tag}>{tag}</a>
      ))}
    </div>

    <section class="scripts-grid">
      {scripts.map((item) => (
        <a
          href={`/tools/${item.slug}`}
          class="script-item"
          data-tags={item.tags.join(",")}
        >
          <div class:list={["script-thumb", !item.thumbnailUrl && "is-empty"]}>
            {item.thumbnailUrl
              ? <img src={`${item.thumbnailUrl}?w=900`} alt={item.title} />
              : <div class="script-thumb-empty">NO IMAGE</div>
            }
          </div>

          <div class="script-meta">
            {item.tags.length > 0 && (
              <div class="script-tags">
                {item.tags.map((tag) => <span class="script-tag">{tag}</span>)}
              </div>
            )}
            <span class="script-title">{item.title}</span>
            {(item.summary || item.description) && (
              <span class="script-desc">{item.summary ?? stripHtml(item.description)}</span>
            )}
          </div>
        </a>
      ))}
    </section>
  </div>
</Layout>

<style>
  .container { padding-top: 40px; }

  .page-head {
    margin-bottom: 28px;
    max-width: 720px;
  }

  .page-desc {
    font-size: 0.8rem;
    color: var(--text-sub);
    line-height: 1.7;
  }

  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px;
    margin-bottom: 34px;
  }

  .tag-link {
    text-decoration: none;
    padding: 7px 0 5px;
    font-size: 0.7rem;
    line-height: 1.35;
    letter-spacing: 0.08em;
    color: var(--text-sub);
    white-space: nowrap;
    border-bottom: 1px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }
  .tag-link:hover {
    color: var(--text-main);
    border-color: #cfcfcf;
  }
  .tag-link[data-tag="all"] {
    border: 1px solid #d7d7d7;
    border-radius: 999px;
    padding: 7px 16px 5px;
    border-bottom-color: #d7d7d7;
  }
  .tag-link.is-active {
    color: var(--text-main);
    border-color: var(--text-main);
  }

  .scripts-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 26px 22px;
  }

  .script-item {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--text-main);
    transition: opacity 0.2s ease;
  }
  .script-item:hover { opacity: 0.75; }
  .script-item.is-hidden { display: none; }
  .script-item.is-out { opacity: 0; }
  .script-item.is-in { opacity: 0; }

  .script-thumb {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #f7f7f7;
    margin-bottom: 12px;
  }

  .script-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .script-thumb-empty {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    font-size: 0.62rem;
    color: var(--text-sub);
    letter-spacing: 0.18em;
  }

  .script-meta {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .script-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .script-tag {
    font-size: 0.56rem;
    color: var(--text-sub);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .script-title {
    font-size: 0.82rem;
    font-weight: 500;
    line-height: 1.45;
  }

  .script-desc {
    font-size: 0.72rem;
    color: var(--text-sub);
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 980px) {
    .scripts-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 680px) {
    .scripts-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 22px 14px;
    }
  }
</style>

<script>
  const FADE = 200;

  function initScriptsTagFilter() {
    const tagLinks = document.querySelectorAll('.tag-link');
    const scriptItems = document.querySelectorAll('.script-item');
    let activeTag = new URLSearchParams(location.search).get('tag') ?? 'all';

    showFilter(activeTag, scriptItems);
    syncActiveState(activeTag, tagLinks);

    tagLinks.forEach((link) => {
      if (link.dataset.bound === "true") return;
      link.dataset.bound = "true";

      link.addEventListener('click', (event) => {
        event.preventDefault();
        activeTag = link.dataset.tag ?? 'all';
        syncActiveState(activeTag, tagLinks);
        animateFilter(activeTag, scriptItems);
        const url = new URL(location.href);
        if (activeTag === 'all') url.searchParams.delete('tag');
        else url.searchParams.set('tag', activeTag);
        history.replaceState(null, '', url);
      });
    });
  }

  function showFilter(tag, scriptItems) {
    scriptItems.forEach((item) => {
      const matches = tag === 'all' || (item.dataset.tags ?? '').split(',').includes(tag);
      item.classList.toggle('is-hidden', !matches);
    });
  }

  function syncActiveState(tag, tagLinks) {
    tagLinks.forEach((link) => link.classList.toggle('is-active', link.dataset.tag === tag));
  }

  function animateFilter(tag, scriptItems) {
    const visible = Array.from(scriptItems).filter((item) => !item.classList.contains('is-hidden'));
    visible.forEach((item) => item.classList.add('is-out'));

    setTimeout(() => {
      scriptItems.forEach((item) => {
        const matches = tag === 'all' || (item.dataset.tags ?? '').split(',').includes(tag);
        item.classList.remove('is-out');
        if (matches) {
          item.classList.remove('is-hidden');
          item.classList.add('is-in');
        } else {
          item.classList.add('is-hidden');
        }
      });

      requestAnimationFrame(() => requestAnimationFrame(() => {
        scriptItems.forEach((item) => item.classList.remove('is-in'));
      }));
    }, FADE);
  }

  document.addEventListener('astro:page-load', initScriptsTagFilter);
  initScriptsTagFilter();
</script>


