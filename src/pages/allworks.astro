---
import Layout from "../layouts/Layout.astro";

type ListingEntry = {
  kind: "dir" | "file";
  marker: "" | "├" | "└";
  name: string;
  href: string;
  modified: string;
  size: string;
  description?: string;
};

type ListingSection = {
  name: string;
  href: string;
  modified: string;
  size: string;
  children: ListingEntry[];
};

const sections: ListingSection[] = [
  {
    name: "商業制作",
    href: "/allworks/commercial/",
    modified: "2026-05-17",
    size: "-",
    children: [
      { kind: "dir", marker: "├", name: "MusicVideo", href: "/allworks/commercial/music-video/", modified: "2026-05-17", size: "-" },
      { kind: "file", marker: "├", name: "インターネット侵略中 / ぱすはに", href: "#", modified: "2024", size: "4K" },
      { kind: "file", marker: "├", name: "歌うたいのバラッド / covered by 長瀬有花", href: "#", modified: "2024", size: "4K" },
      { kind: "file", marker: "├", name: "sweetdevil / covered by 茨むあん", href: "#", modified: "2024", size: "4K" },
      { kind: "file", marker: "├", name: "真的没喝多 / covered by If", href: "#", modified: "2024", size: "4K" },
      { kind: "file", marker: "├", name: "ネオンライト・グルーヴ / rukaku", href: "#", modified: "2024", size: "4K" },
      { kind: "file", marker: "├", name: "幽玄アルゴリズム / rukaku", href: "#", modified: "2024", size: "4K" },
      { kind: "file", marker: "└", name: "* this game does not exist * / litmus* x Ester", href: "#", modified: "2024", size: "5K", description: "一部3DCG・コンポジット" },
    ],
  },
  {
    name: "背景映像演出",
    href: "/allworks/background/",
    modified: "2026-05-17",
    size: "-",
    children: [
      { kind: "file", marker: "├", name: "にじさんじフェス2022 月ノ美兎&星川サラ&不破湊&ChroNoiRステージ", href: "#", modified: "2022", size: "6K" },
      { kind: "file", marker: "├", name: "にじさんじ 5th Anniversary LIVE 「SYMPHONIA」", href: "#", modified: "2024", size: "6K" },
      { kind: "file", marker: "├", name: "ROF-MAO 1st Live ｢New street, New world」", href: "#", modified: "2024", size: "6K" },
      { kind: "file", marker: "└", name: "さんばか 5th Anniversary LIVE 〜３！参！SUN！〜", href: "#", modified: "2024", size: "5K" },
    ],
  },
  {
    name: "リリックモーション演出",
    href: "/allworks/lyric-motion/",
    modified: "2026-05-17",
    size: "-",
    children: [
      { kind: "file", marker: "├", name: "Ethyria's First 3D Live Concert", href: "#", modified: "2024", size: "5K" },
      { kind: "file", marker: "├", name: "3Dでどーーーんっ！！これが最強な倉持だぁぁぁ！！！", href: "#", modified: "2024", size: "4K" },
      { kind: "file", marker: "└", name: "ゲストたくさん！！重大発表あり！！なハッピー誕生日3Dライブ！！！！", href: "#", modified: "2024", size: "5K" },
    ],
  },
];
---

<Layout title="Index of /allworks/" hideNav hideFooter noindex>
  <main class="apache-index">
    <h1>Index of /allworks/</h1>

    <table class="listing" aria-label="Index of /allworks/">
      <thead>
        <tr>
          <th class="icon"></th>
          <th class="name"><a href="?C=N;O=D">Name</a></th>
          <th class="modified"><a href="?C=M;O=A">Last modified</a></th>
          <th class="size"><a href="?C=S;O=A">Size</a></th>
          <th class="description"><a href="?C=D;O=A">Description</a></th>
        </tr>
      </thead>
      <tbody>
        <tr class="parent-row">
          <td class="icon"><img src="/assets/apache-parent.svg" alt="" /></td>
          <td class="name"><a href="/">Parent Directory</a></td>
          <td class="modified">-</td>
          <td class="size">-</td>
          <td class="description"></td>
        </tr>

        {sections.map((section) => (
          <>
            <tr class="section-row">
              <td class="icon"><img src="/assets/apache-folder.svg" alt="" /></td>
              <td class="name"><a href={section.href}>{section.name}/</a></td>
              <td class="modified">{section.modified}</td>
              <td class="size">{section.size}</td>
              <td class="description"></td>
            </tr>
            {section.children.map((entry) => (
              <tr>
                <td class="icon"><img src={entry.kind === "dir" ? "/assets/apache-folder.svg" : "/assets/apache-file.svg"} alt="" /></td>
                <td class="name child-name">
                  <span class="tree">{entry.marker}</span>
                  <a href={entry.href}>{entry.kind === "dir" ? `${entry.name}/` : entry.name}</a>
                </td>
                <td class="modified">{entry.modified}</td>
                <td class="size">{entry.size}</td>
                <td class="description">{entry.description ?? "-"}</td>
              </tr>
            ))}
          </>
        ))}
      </tbody>
    </table>

    <address>
      Apache/2.4.18 (pseudo) Server at onmk.work, onmk<br />
      onmokoworks(at)gmail.com
    </address>
  </main>
</Layout>

<style>
  :global(html),
  :global(body) {
    background: #fff;
  }

  .apache-index {
    min-height: 100vh;
    margin-top: calc(-1 * var(--nav-height));
    padding: 10px 20px 14px;
    overflow-x: visible;
    background: #fff;
    color: #000;
    font-family: "Courier New", Courier, monospace;
    font-size: 14px;
    line-height: 1.15;
  }

  h1 {
    margin: 0 0 12px;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 22px;
    font-weight: 400;
  }

  .listing {
    width: 100%;
    max-width: 1040px;
    border-collapse: collapse;
    border-top: 1px solid #aaa;
    border-bottom: 1px solid #aaa;
  }

  th,
  td {
    padding: 2px 7px 2px 0;
    text-align: left;
    vertical-align: top;
    font-weight: 400;
  }

  thead th {
    padding-top: 5px;
    padding-bottom: 5px;
    border-bottom: 1px solid #aaa;
  }

  .icon {
    width: 26px;
    min-width: 26px;
    padding-right: 4px;
  }

  .icon img {
    display: block;
    width: 20px;
    height: 22px;
    image-rendering: pixelated;
  }

  .name {
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: normal;
  }

  .modified {
    width: 9em;
    white-space: nowrap;
  }

  .size {
    width: 3.5em;
    text-align: right;
    white-space: nowrap;
  }

  .description {
    width: 15em;
  }

  .parent-row td,
  .section-row td {
    padding-top: 8px;
  }

  .tree {
    display: inline-block;
    min-width: 1.4em;
    color: #000;
    white-space: pre;
  }

  a {
    color: #00e;
    text-decoration: underline;
  }

  a:visited {
    color: #551a8b;
  }

  address {
    max-width: 1040px;
    margin-top: 8px;
    padding-top: 6px;
    border-top: 1px solid #aaa;
    font-style: italic;
  }

  @media (max-width: 640px) {
    .apache-index {
      padding: 8px 10px 12px;
      font-size: 12px;
    }

    h1 {
      margin-bottom: 10px;
      font-size: 18px;
    }

    th,
    td {
      padding-top: 2px;
      padding-bottom: 2px;
    }

    .icon {
      width: 22px;
      min-width: 22px;
    }

    .icon img {
      width: 18px;
      height: 20px;
    }

    .modified,
    .description {
      display: none;
    }

    .size {
      width: 2.8em;
      padding-right: 0;
      font-size: 11px;
    }

    .tree {
      min-width: 1em;
    }

    address {
      font-size: 11px;
    }
  }

  @media (max-width: 390px) {
    .apache-index {
      padding-right: 8px;
      padding-left: 8px;
      font-size: 11px;
    }

    h1 {
      font-size: 16px;
    }

    .size {
      display: none;
    }
  }
</style>
