---
import Layout from "../layouts/Layout.astro";
import allworksSource from "../data/allworks.md?raw";

type WorkEntry = {
  name: string;
  href: string;
  year: string;
  description?: string;
};

type WorkSection = {
  name: string;
  children: WorkEntry[];
};

function parseLink(value: string) {
  const match = value.match(/^\[(.+)\]\((.+)\)$/);
  if (!match) return { name: value, href: "#" };
  return { name: match[1], href: match[2] };
}

function parseAllWorks(source: string): WorkSection[] {
  const sections: WorkSection[] = [];

  for (const rawLine of source.split(/\r?\n/)) {
    const line = rawLine.trim();
    if (!line) continue;

    const heading = line.match(/^##\s+(.+)$/);
    if (heading) {
      sections.push({ name: heading[1].trim(), children: [] });
      continue;
    }

    if (!line.startsWith("- ")) continue;
    const current = sections.at(-1);
    if (!current) continue;

    const [year = "", title = "", description] = line
      .slice(2)
      .split("|")
      .map((value) => value.trim());
    if (!title) continue;

    current.children.push({
      ...parseLink(title),
      year,
      description,
    });
  }

  return sections;
}

const sections = parseAllWorks(allworksSource);
---

<Layout title="all works | onmk" hideNav hideFooter>
  <main class="allworks-page">
    <h1>All Works</h1>

    <div class="work-list" aria-label="All works">
      {sections.map((section) => (
        <section class="work-section">
          <h2>{section.name}</h2>

          {section.children.map((entry) => (
            <div class="work-row">
              <a href={entry.href}>{entry.name}</a>
              <span class="work-meta">
                {entry.year}
                {entry.description && ` / ${entry.description}`}
              </span>
            </div>
          ))}
        </section>
      ))}
    </div>
  </main>
</Layout>

<style>
  .allworks-page {
    padding-top: 40px;
    max-width: 760px;
  }

  h1 {
    margin: 0 0 34px;
    font-size: 1.15rem;
    font-weight: 500;
    line-height: 1.4;
  }

  .work-list {
    display: flex;
    flex-direction: column;
    gap: 34px;
  }

  .work-section {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  h2 {
    margin: 0 0 4px;
    font-size: 0.82rem;
    font-weight: 500;
    line-height: 1.5;
  }

  .work-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 18px;
    align-items: baseline;
    padding-left: 1.2em;
    font-size: 0.78rem;
    line-height: 1.7;
  }

  .work-row a {
    min-width: 0;
  }

  .work-meta {
    color: var(--text-sub);
    font-size: 0.68rem;
    white-space: nowrap;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  a:hover {
    color: var(--text-sub);
  }

  @media (max-width: 640px) {
    h1 {
      margin-bottom: 28px;
    }

    .work-list {
      gap: 30px;
    }

    .work-row {
      grid-template-columns: 1fr;
      gap: 1px;
    }

    .work-meta {
      white-space: normal;
    }
  }
</style>
