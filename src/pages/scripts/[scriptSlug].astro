---
import { getTools } from '../../library/microcms';

export async function getStaticPaths() {
  const response = await getTools({ fields: ["id", "slug"], limit: 100 });
  return response.contents.map((tool) => ({
    params: { scriptSlug: tool.slug ?? tool.id },
  }));
}

const { scriptSlug } = Astro.params;
return Astro.redirect(`/tools/${scriptSlug ?? ''}`, 308);
---
