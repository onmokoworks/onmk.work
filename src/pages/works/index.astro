---
import Layout from "../../layouts/Layout.astro";
import { getWorks, getTags } from "../../library/microcms";

const [worksRes, tagsRes] = await Promise.all([
  getWorks({ orders: "-publishedAt", limit: 100 }),
  getTags({ limit: 100 }),
]);

const works = worksRes.contents;
const tags = tagsRes.contents;
---

<Layout title="works | onmk">
  <div class="container">
    <div class="tag-filter" aria-label="Filter works by tag">
      <a href="/works" class="tag-link" data-tag="all">all</a>
      {tags.map((tag) => (
        <a href={`/works?tag=${tag.id}`} class="tag-link" data-tag={tag.id}>{tag.title}</a>
      ))}
    </div>

    <section class="works-grid">
      {works.map((work) => (
        <a
          href={`/works/${work.id}`}
          class="work-item"
          data-tags={work.tag ? work.tag.map(t => t.id).join(",") : ""}
        >
          <div class="work-thumb">
            {work.images?.[0]
              ? <img src={`${work.images[0].url}?w=800`} alt={work.title} />
              : <div class="work-thumb-empty" />
            }
          </div>
          <div class="work-info">
            <span class="work-year">{new Date(work.publishedAt).getFullYear()}</span>
            <span class="work-title">{work.title}</span>
          </div>
        </a>
      ))}
    </section>
  </div>
</Layout>

<style>
  .container { padding-top: 40px; }

  /* Tag Filter */
  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px;
    margin-bottom: 40px;
  }

  .tag-link {
    text-decoration: none;
    padding: 7px 0 5px;
    font-size: 0.7rem;
    line-height: 1.35;
    letter-spacing: 0.08em;
    color: var(--text-sub);
    white-space: nowrap;
    border-bottom: 1px solid transparent;
    transition: color 0.2s, border-color 0.2s, background-color 0.2s;
  }
  .tag-link:hover {
    color: var(--text-main);
    border-color: #cfcfcf;
  }
  .tag-link[data-tag="all"] {
    border: 1px solid #d7d7d7;
    border-radius: 999px;
    padding: 7px 16px 5px;
    border-bottom-color: #d7d7d7;
  }
  .tag-link[data-tag="all"]:hover {
    border-color: #bdbdbd;
  }
  .tag-link.is-active {
    color: var(--text-main);
    border-color: var(--text-main);
  }

  /* Works Grid */
  .works-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
  }
  .work-item {
    text-decoration: none;
    color: var(--text-main);
    transition: opacity 0.2s ease;
  }
  .work-item.is-hidden { display: none; }
  .work-item.is-out { opacity: 0; }
  .work-item.is-in { opacity: 0; }

  .work-thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #000;
    margin-bottom: 12px;
    overflow: hidden;
  }
  .work-thumb img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .work-item:hover .work-thumb img { transform: scale(1.05); }
  .work-thumb-empty { width: 100%; height: 100%; background-color: #111; }

  .work-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    letter-spacing: 0.01em;
  }
  .work-year {
    font-size: 0.55rem;
    color: var(--text-sub);
    font-style: normal;
  }
  .work-title {
    font-size: 0.8rem;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .works-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const FADE = 200;

  function initWorksTagFilter() {
    const tagLinks = document.querySelectorAll<HTMLAnchorElement>('.tag-link');
    const workItems = document.querySelectorAll<HTMLElement>('.work-item');
    let activeTag = new URLSearchParams(location.search).get('tag') ?? 'all';

    showFilter(activeTag, workItems);
    syncActiveState(activeTag, tagLinks);

    tagLinks.forEach(link => {
      if (link.dataset.bound === "true") return;
      link.dataset.bound = "true";

      link.addEventListener('click', (event) => {
        event.preventDefault();
        activeTag = link.dataset.tag ?? 'all';
        syncActiveState(activeTag, tagLinks);
        animateFilter(activeTag, workItems);
        const url = new URL(location.href);
        if (activeTag === 'all') url.searchParams.delete('tag');
        else url.searchParams.set('tag', activeTag);
        history.replaceState(null, '', url);
      });
    });
  }

  // アニメーションなし（初期表示用）
  function showFilter(tag: string, workItems: NodeListOf<HTMLElement>) {
    workItems.forEach(item => {
      const matches = tag === 'all' || (item.dataset.tags ?? '').split(',').includes(tag);
      item.classList.toggle('is-hidden', !matches);
    });
  }

  function syncActiveState(tag: string, tagLinks: NodeListOf<HTMLAnchorElement>) {
    tagLinks.forEach(link => link.classList.toggle('is-active', link.dataset.tag === tag));
  }

  // フェードアウト → リフロー → フェードイン
  function animateFilter(tag: string, workItems: NodeListOf<HTMLElement>) {
    // 1. 表示中アイテムをフェードアウト
    const visible = Array.from(workItems).filter(i => !i.classList.contains('is-hidden'));
    visible.forEach(i => i.classList.add('is-out'));

    setTimeout(() => {
      // 2. display切り替え（opacity:0 の状態なのでリフローが見えない）
      workItems.forEach(item => {
        const matches = tag === 'all' || (item.dataset.tags ?? '').split(',').includes(tag);
        item.classList.remove('is-out');
        if (matches) {
          item.classList.remove('is-hidden');
          item.classList.add('is-in');
        } else {
          item.classList.add('is-hidden');
        }
      });

      // 3. フェードイン
      requestAnimationFrame(() => requestAnimationFrame(() => {
        workItems.forEach(i => i.classList.remove('is-in'));
      }));
    }, FADE);
  }

  document.addEventListener('astro:page-load', initWorksTagFilter);
  initWorksTagFilter();
</script>
