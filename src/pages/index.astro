---
import Layout from "../layouts/Layout.astro";
import { getWorks } from "../library/microcms";

const worksRes = await getWorks({ orders: "-publishedAt", limit: 4 });
const recentWorks = worksRes.contents;
---

<Layout title="onmk">
  <div class="container">
    <section class="recently-works">
      <span class="section-title">Recently Works</span>
      <div class="recent-grid">
        {recentWorks.map((work) => (
          <a href={`/works/${work.id}`} class="recent-item">
            <div class="recent-thumb">
              {work.images?.[0]
                ? <img src={`${work.images[0].url}?w=800`} alt={work.title} />
                : <div class="recent-thumb-empty" />
              }
            </div>
            <div class="recent-info">
              <span class="recent-year">{new Date(work.publishedAt).getFullYear()}</span>
              <span style="font-weight:500">{work.title}</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  </div>
</Layout>

<style>
  .section-title {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 30px;
    display: block;
  }
  .recent-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
  }
  .recent-item { text-decoration: none; color: var(--text-main); }
  .recent-thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: var(--accent);
    margin-bottom: 12px;
    overflow: hidden;
  }
  .recent-thumb img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .recent-item:hover .recent-thumb img { transform: scale(1.05); }
  .recent-thumb-empty { width: 100%; height: 100%; background-color: var(--text-main); opacity: 0.2; }
  .recent-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    letter-spacing: 0.01em;
  }
  .recent-year {
    font-size: 0.55rem;
    color: var(--text-sub);
    font-style: normal;
  }
  :global(.idle-screen) {
    position: fixed;
    inset: 0;
    z-index: 1999;
    display: none;
    overflow: hidden;
    pointer-events: none;
  }
  :global(.idle-screen.is-active) {
    display: block;
  }
  :global(html.is-idle-screen),
  :global(html.is-idle-screen body) {
    overflow: hidden;
  }
  :global(.idle-backdrop) {
    position: absolute;
    inset: 0;
    background: #fff;
  }
  :global(html[data-theme="dark"] .idle-backdrop),
  :global(html[data-theme="flashlight"] .idle-backdrop) {
    background: #000;
  }
  :global(.idle-logo) {
    position: absolute;
    left: 0;
    top: 0;
    z-index: 1;
    pointer-events: none;
    color: var(--text-main);
    font-size: clamp(1.4rem, 5vw, 3.2rem);
    font-style: italic;
    font-weight: 400;
    line-height: 1;
    opacity: 0.82;
    will-change: transform;
  }
  @media (max-width: 768px) {
    .recent-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const IDLE_DELAY = 45000;
  const SPEED = 1.15;

  function initIdleLogo() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (window.__onmkIdleCleanup) window.__onmkIdleCleanup();

    let screen = document.getElementById('idle-screen');
    if (!screen) {
      screen = document.createElement('div');
      screen.id = 'idle-screen';
      screen.className = 'idle-screen';
      document.body.appendChild(screen);
    }

    let backdrop = document.getElementById('idle-backdrop');
    if (!backdrop) {
      backdrop = document.createElement('div');
      backdrop.id = 'idle-backdrop';
      backdrop.className = 'idle-backdrop';
    }
    screen.appendChild(backdrop);

    let logo = document.getElementById('idle-logo');
    if (!logo) {
      logo = document.createElement('div');
      logo.id = 'idle-logo';
      logo.className = 'idle-logo';
      logo.textContent = 'onmk';
    }
    screen.appendChild(logo);

    let idleTimer = 0;
    let animationFrame = 0;
    let active = false;
    let x = 24;
    let y = 24;
    let dx = SPEED;
    let dy = SPEED;

    const resetPosition = () => {
      const rect = logo.getBoundingClientRect();
      x = Math.max(16, Math.random() * Math.max(1, screen.clientWidth - rect.width - 32));
      y = Math.max(16, Math.random() * Math.max(1, screen.clientHeight - rect.height - 32));
      dx = Math.random() > 0.5 ? SPEED : -SPEED;
      dy = Math.random() > 0.5 ? SPEED : -SPEED;
      logo.style.transform = `translate3d(${x}px, ${y}px, 0)`;
    };

    const tick = () => {
      if (!active) return;

      const rect = logo.getBoundingClientRect();
      const maxX = Math.max(0, screen.clientWidth - rect.width);
      const maxY = Math.max(0, screen.clientHeight - rect.height);

      x += dx;
      y += dy;

      if (x <= 0 || x >= maxX) {
        dx *= -1;
        x = Math.max(0, Math.min(x, maxX));
      }
      if (y <= 0 || y >= maxY) {
        dy *= -1;
        y = Math.max(0, Math.min(y, maxY));
      }

      logo.style.transform = `translate3d(${x}px, ${y}px, 0)`;
      animationFrame = requestAnimationFrame(tick);
    };

    const start = () => {
      if (active) return;
      active = true;
      screen.classList.add('is-active');
      document.documentElement.classList.add('is-idle-screen');
      resetPosition();
      animationFrame = requestAnimationFrame(tick);
    };

    const stop = () => {
      active = false;
      screen.classList.remove('is-active');
      document.documentElement.classList.remove('is-idle-screen');
      if (animationFrame) cancelAnimationFrame(animationFrame);
      animationFrame = 0;
    };

    const schedule = () => {
      stop();
      if (idleTimer) window.clearTimeout(idleTimer);
      idleTimer = window.setTimeout(start, IDLE_DELAY);
    };

    const activityEvents = ['mousemove', 'mousedown', 'keydown', 'scroll', 'touchstart'];
    const handleVisibilityChange = () => {
      if (document.hidden) stop();
      else schedule();
    };

    activityEvents.forEach((eventName) => {
      window.addEventListener(eventName, schedule, { passive: true });
    });

    window.addEventListener('resize', schedule, { passive: true });
    document.addEventListener('visibilitychange', handleVisibilityChange);

    window.__onmkIdleCleanup = () => {
      stop();
      if (idleTimer) window.clearTimeout(idleTimer);
      activityEvents.forEach((eventName) => {
        window.removeEventListener(eventName, schedule);
      });
      window.removeEventListener('resize', schedule);
      document.removeEventListener('visibilitychange', handleVisibilityChange);
    };

    schedule();
  }

  document.addEventListener('astro:page-load', initIdleLogo);
  initIdleLogo();
</script>
