---
import Layout from "../layouts/Layout.astro";

const notFoundAnimationSources = [
  "/assets/404/001-otadesign.png",
  "/assets/404/002-glitch.png",
  "/assets/404/003-pixels.png",
];
---

<Layout title="onmk" noindex>
  <div class="not-found-shell">
    <div class="container not-found-content">
      <div class="not-found-visual">
        <img
          src={notFoundAnimationSources[0]}
          alt=""
          class="not-found-animation"
          data-404-animation
          loading="eager"
          decoding="async" />
      </div>
      <p class="description">
        &#12362;&#25506;&#12375;&#12398;&#12506;&#12540;&#12472;&#12399;&#35211;&#12388;&#12363;&#12426;&#12414;&#12379;&#12435;&#12391;&#12375;&#12383;&#12290;
      </p>
    </div>
  </div>
</Layout>

<script define:vars={{ notFoundAnimationSources }}>
  const animation = document.querySelector("[data-404-animation]");
  if (animation instanceof HTMLImageElement && notFoundAnimationSources.length > 1) {
    const index = Math.floor(Math.random() * notFoundAnimationSources.length);
    animation.src = notFoundAnimationSources[index];
  }
</script>

<style>
  .not-found-shell {
    min-height: calc(100vh - var(--nav-height));
    display: grid;
    place-items: center;
  }

  .not-found-content {
    min-height: calc(100vh - var(--nav-height));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0;
    text-align: center;
  }

  .not-found-visual {
    width: min(76vw, 560px);
    max-width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .not-found-animation {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: contain;
    image-rendering: auto;
  }

  .description {
    margin-top: 18px;
    font-size: 0.92rem;
    line-height: 1.9;
    color: var(--text-sub);
  }

  @media (max-width: 768px) {
    .not-found-content {
      padding: 40px 20px;
    }

    .not-found-visual {
      width: min(82vw, 420px);
    }

    .description {
      font-size: 0.88rem;
    }
  }
</style>
